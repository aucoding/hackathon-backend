import time, base64
from databricks.sdk.service.jobs import SubmitTask, NotebookTask, RunLifeCycleState
from databricks.sdk.service.workspace import ImportFormat, Language

# 1. Create a temporary failing notebook
fail_path = "/Users/extadmvasri@pandora.net/_fail_on_purpose"
notebook_content = base64.b64encode(
    b'raise RuntimeError("Intentional failure for Collector Agent e2e test")'
).decode()
w.workspace.import_(
    path=fail_path,
    format=ImportFormat.SOURCE,
    language=Language.PYTHON,
    content=notebook_content,
    overwrite=True,
)
print(f"\u2713 Failing notebook created at {fail_path}")

# 2. Submit 3 runs that will all fail
run_ids = []
for i in range(1, 4):
    submit = w.jobs.submit(
        run_name=f"collector_e2e_fail_{i}",
        tasks=[
            SubmitTask(
                task_key="fail_task",
                notebook_task=NotebookTask(notebook_path=fail_path),
            )
        ],
    )
    rid = submit.bind()["run_id"]
    run_ids.append(rid)
    print(f"\u2713 Run {i} submitted: run_id={rid}")

# 3. Wait for all runs to finish
print("\nWaiting for all runs to complete...")
for rid in run_ids:
    while True:
        run = w.jobs.get_run(run_id=rid)
        state = run.state.life_cycle_state
        if state in (RunLifeCycleState.TERMINATED, RunLifeCycleState.INTERNAL_ERROR, RunLifeCycleState.SKIPPED):
            print(f"  run_id={rid}  result={run.state.result_state}")
            break
        time.sleep(10)

print("\n\u2713 All 3 runs finished. Now re-run Cell 1 to collect and ship these failures.")
